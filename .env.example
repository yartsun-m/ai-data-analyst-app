# Google Gemini (LLM chat)
# Comma-separated — rotated automatically on rate limits (429)
GEMINI_API_KEYS=key1,key2,key3
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Priority order: best quality → fast/cheap fallback
GEMINI_MODELS=gemini-3.5-flash,gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite
GEMINI_MAX_RETRIES=2

# Backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEBUG=false
MAX_UPLOAD_SIZE_MB=50

# Frontend (used at build time in Docker)
NEXT_PUBLIC_API_URL=http://localhost:8000
