# Google Gemini (LLM chat)
GEMINI_API_KEYS=key1,key2
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3.5-flash,gemini-3.1-flash-lite
GEMINI_MAX_RETRIES=2

# Backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://ai-data-analyst-app-sigma.vercel.app
DEBUG=false
MAX_UPLOAD_SIZE_MB=50
CV_FOLDS=3
ENABLE_HYPERPARAMETER_TUNING=true
CHAT_HISTORY_LIMIT=10

# Rate limits
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_TRAIN=5/minute
RATE_LIMIT_ASK=20/minute

# Frontend (build-time in Docker / Vercel)
NEXT_PUBLIC_API_URL=http://localhost:8000
